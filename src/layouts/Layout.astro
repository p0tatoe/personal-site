---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
    title?: string;
}

const { title = "Michael Lee" } = Astro.props;

// Fetch all markdown files in the blog directory to list in the sidebar dropdown dynamically
// We read files directly from filesystem to avoid Vite circular dependency imports
let posts: { url: string; title: string }[] = [];
try {
    const blogDir = path.resolve('./src/pages/blog');
    if (fs.existsSync(blogDir)) {
        const files = fs.readdirSync(blogDir);
        for (const file of files) {
            if (file.endsWith('.md')) {
                const filePath = path.join(blogDir, file);
                const content = fs.readFileSync(filePath, 'utf-8');
                const lines = content.split('\n');
                let postTitle = file.replace('.md', '');
                for (const line of lines) {
                    if (line.trim().startsWith('title:')) {
                        postTitle = line.replace('title:', '').trim().replace(/^["']|["']$/g, '');
                        break;
                    }
                }
                const slug = file.replace('.md', '');
                posts.push({
                    url: `/blog/${slug}`,
                    title: postTitle
                });
            }
        }
    }
} catch (e) {
    console.error("Error reading blog posts for sidebar: ", e);
}

// Generate the HTML string for the sidebar links in the frontmatter.
// This prevents Astro's JSX template compiler from hitting mapping/parsing glitches.
const blogLinksHtml = `
    <p style="margin: 5px 0;"><a href="/blog">All Posts</a></p>
    ${posts.map(post => `
        <p style="margin: 5px 0;">
            <a href="${post.url}">${post.title}</a>
        </p>
    `).join('')}
`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <style is:global>
            html, body {
                background-color: #121212;
                color: #ffffff;
                font-family: sans-serif;
            }
            a {
                color: #88a7fd;
            }
            a:visited {
                color: #f490fd;
            }
            a:active {
                color: #88a7fd;
            }
        </style>
    </head>
    <body>
        <table border="0" cellpadding="10" cellspacing="0" width="100%">
            <tr>
                <!-- Sidebar Column -->
                <td
                    valign="top"
                    width="200"
                    style="border-right: 1px solid currentColor; padding-right: 20px;"
                >
                    <h3>Michael Lee</h3>
                    <p><a href="/">Welcome</a></p>
                    
                    <!-- Blog Collapsable Dropdown -->
                    <details open>
                        <summary style="cursor: pointer; font-weight: bold; margin-bottom: 5px;">Blog</summary>
                        <div style="padding-left: 15px; margin-bottom: 10px;" set:html={blogLinksHtml}>
                        </div>
                    </details>

                    <!-- Free Blocker Collapsable Dropdown -->
                    <details open>
                        <summary style="cursor: pointer; font-weight: bold; margin-top: 10px; margin-bottom: 5px;">Free Blocker</summary>
                        <div style="padding-left: 15px; margin-bottom: 10px;">
                            <p style="margin: 5px 0;"><a href="/free-blocker/info">Info</a></p>
                            <p style="margin: 5px 0;"><a href="/free-blocker/privacy-policy">Privacy Policy</a></p>
                        </div>
                    </details>

                    <hr />
                    <p>
                        <a href="mailto:michael.yarmouth.lee@gmail.com"
                            >Email</a>
                    </p>
                    <p>
                        <a
                            href="https://www.linkedin.com/in/michael-y-lee7/"
                            target="_blank">LinkedIn</a>
                    </p>
                    <p>
                        <a href="https://github.com/p0tatoe" target="_blank"
                            >GitHub</a>
                    </p>
                </td>
                <!-- Content Column -->
                <td valign="top" style="padding-left: 20px;">
                    <slot />
                </td>
            </tr>
        </table>
    </body>
</html>
