---
import { Font } from "astro:assets";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Michael Lee</title>
        <Font cssVariable="--font-league-gothic" />
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    html,
    :root {
        --primary-color: #ff5d01;
        --font-fallback: system-ui, sans-serif;
    }

    body {
        background-color: #13151a;
        font-family: var(--font-fallback);
        color: white;
        margin: 0;
        width: 100%;
        height: 100%;
    }

    h1 {
        font-family: var(--font-league-gothic), sans-serif;
        font-size: 50px;
    }

    a {
        color: #FF9800
    }

</style>
