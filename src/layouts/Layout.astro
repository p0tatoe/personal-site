<style is:global>
    html,
    :root {
        --primary-color: #ff5d01;
        --font-fallback: system-ui, sans-serif;
    }

    body {
        background-color: #13151a;
        font-family: var(--font-fallback);
        color: white;
        margin: 0;
        width: 100%;
        height: 100%;
    }

    h1 {
        font-family: var(--font-league-gothic), sans-serif;
        font-size: 50px;
    }

    a {
        color: #FF9800
    }

    .email-link, .linkedin-link, .github-link {
        text-decoration: none;
        display: inline-block; /* Forces the browser to treat the link purely as a box container */
    }

</style>
