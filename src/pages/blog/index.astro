---
import Layout from "../../layouts/Layout.astro";

// Use import.meta.glob to fetch all markdown files in the blog directory
const posts = Object.values(import.meta.glob("./*.md", { eager: true })) as any[];
---

<Layout title="Blog">
    <h1>Blog</h1>
    <p>Welcome to my blog! Check out my posts below:</p>

    <ul>
        {
            posts.map((post) => (
                <li>
                    <a href={post.url}>{post.frontmatter.title}</a>
                </li>
            ))
        }
    </ul>
</Layout>
